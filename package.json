{
  "name": "follow-the-money",
  "version": "1.0.0",
  "description": "Personal investment portfolio tracking application",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test && npm run test:e2e"
  },
  "keywords": [
    "investment",
    "portfolio",
    "tracking"
  ],
  "author": "shay",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@vitest/coverage-v8": "^1.6.1",
    "dotenv": "^17.2.3",
    "jsdom": "^27.0.1",
    "vitest": "^1.6.1"
  }
}
